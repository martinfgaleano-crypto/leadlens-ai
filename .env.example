# ═══════════════════════════════════════════════════════════════════════════════
# LeadLens AI — Environment Variables
# Copy this file to .env.local and fill in the values you need.
# NEVER commit .env.local — it is listed in .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── REQUIRED: Public website (Vercel) ────────────────────────────────────────
# These three are the only vars needed to run the public site in DEMO_MODE.

DEMO_MODE=true
ALLOW_MOCK_LEADS_WITH_REAL_AI=false
NEXT_PUBLIC_APP_URL=https://leadlens-ai-xi.vercel.app

# ─── STEP 1 AFTER LEMON SQUEEZY APPROVAL: Checkout links ─────────────────────
# Get these from: app.lemonsqueezy.com → Products → [product] → Share button
#
# These are PUBLIC direct-pay URLs — safe to expose as NEXT_PUBLIC env vars.
# They contain no secrets. When set, pricing buttons redirect to LS checkout.
# When empty, pricing buttons fall back to the onboarding form.
#
# No API key or webhook needed for this step.

NEXT_PUBLIC_LEMONSQUEEZY_SAMPLE_URL=
NEXT_PUBLIC_LEMONSQUEEZY_STARTER_URL=
NEXT_PUBLIC_LEMONSQUEEZY_STANDARD_URL=
NEXT_PUBLIC_LEMONSQUEEZY_PRO_URL=

# ─── STEP 2 (OPTIONAL LATER): Lemon Squeezy API + webhooks ───────────────────
# Only needed if you want automated webhook confirmation or API-created checkouts.
# Not required to accept payments via direct checkout links.

LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_SAMPLE=
LEMONSQUEEZY_VARIANT_STARTER=
LEMONSQUEEZY_VARIANT_STANDARD=
LEMONSQUEEZY_VARIANT_PRO=

# ─── Anthropic (required when DEMO_MODE=false) ────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Hybrid test mode ─────────────────────────────────────────────────────────
# true = Claude agents run with mock leads (no real lead provider needed)
# ALLOW_MOCK_LEADS_WITH_REAL_AI=false  (set above in required section)

# ─── Lead providers (at least one required when DEMO_MODE=false) ──────────────
APOLLO_API_KEY=
PEOPLE_DATA_LABS_API_KEY=
TAVILY_API_KEY=
HUNTER_API_KEY=

# ─── Stripe (paused — not available for Colombian merchants) ──────────────────
# Kept for future reference (Stripe Atlas / US entity path)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_STANDARD=
# STRIPE_PRICE_PRO=

# ─── Supabase (required for order persistence + admin dashboard + customer auth) ─
# See SUPABASE_SETUP.md for step-by-step setup instructions.
# NEXT_PUBLIC_SUPABASE_URL        — required for all Supabase features
# SUPABASE_SERVICE_ROLE_KEY       — server-side only (admin API, webhooks, pipeline)
# NEXT_PUBLIC_SUPABASE_ANON_KEY   — required for customer login/signup (/login, /signup, /dashboard)

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── SaaS Foundation: Admin API protection ────────────────────────────────────
# Protects /api/admin/* routes. Set a strong random string.
# Generate one: openssl rand -hex 32
# In development, missing token is allowed with a console warning.
# In production, this MUST be set or all admin routes return 403.

ADMIN_SECRET_TOKEN=

# ─── Email delivery via Resend (optional — manual delivery works without) ─────
RESEND_API_KEY=
FROM_EMAIL=reports@yourdomain.com
