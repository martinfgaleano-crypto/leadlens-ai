# ─── Demo mode ────────────────────────────────────────────────────────────────
# true = full pipeline with zero external APIs (safe for preview deploys)
# false = requires Anthropic key + at least one lead provider
DEMO_MODE=true

# ─── Anthropic (required when DEMO_MODE=false) ────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Hybrid test mode ─────────────────────────────────────────────────────────
# true = Claude agents run with mock leads (no real lead provider needed)
ALLOW_MOCK_LEADS_WITH_REAL_AI=false

# ─── Lead providers (at least one required when DEMO_MODE=false) ──────────────
APOLLO_API_KEY=
PEOPLE_DATA_LABS_API_KEY=
TAVILY_API_KEY=
HUNTER_API_KEY=

# ─── Lemon Squeezy (payment provider — required to accept real payments) ───────
# Get from: app.lemonsqueezy.com → Settings → API Keys
LEMONSQUEEZY_API_KEY=
# Get from: app.lemonsqueezy.com → Settings → Store (numeric ID)
LEMONSQUEEZY_STORE_ID=
# Get from: app.lemonsqueezy.com → Settings → Webhooks → signing secret
LEMONSQUEEZY_WEBHOOK_SECRET=
# Variant IDs from each product in your LS store
LEMONSQUEEZY_VARIANT_STARTER=
LEMONSQUEEZY_VARIANT_STANDARD=
LEMONSQUEEZY_VARIANT_PRO=

# Direct checkout URLs (optional — from your LS product's "Share" link)
# When set, pricing buttons redirect straight to LS checkout (skips the onboarding form)
# Leave empty to use the onboarding form flow instead
NEXT_PUBLIC_LEMONSQUEEZY_STARTER_URL=
NEXT_PUBLIC_LEMONSQUEEZY_STANDARD_URL=
NEXT_PUBLIC_LEMONSQUEEZY_PRO_URL=

# ─── Stripe (paused — not available for Colombian merchants) ──────────────────
# Kept for future reference (Stripe Atlas / US entity path)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_STANDARD=
# STRIPE_PRICE_PRO=

# ─── Supabase (optional — in-memory job store works without it) ───────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Email delivery via Resend (optional — manual delivery works without) ─────
RESEND_API_KEY=
FROM_EMAIL=reports@yourdomain.com

# ─── App URL (set to your Vercel URL after deploy) ───────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
